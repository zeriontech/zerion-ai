{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": [
    "zerion.js",
    "router.js",
    "commands/**/*",
    "lib/**/*",
    "policies/**/*",
    "tests/**/*"
  ]
}
